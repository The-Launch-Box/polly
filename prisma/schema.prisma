generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Form {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  themeId     String       @default("default")
  anonymous   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  questions   Question[]
  submissions Submission[]
}

enum QuestionType {
  SCALE
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SHORT_TEXT
  SLIDER
  HEATMAP
  ATTACHMENT
  NPS
  CONTACT_INFO
}

model Question {
  id        String       @id @default(cuid())
  formId    String
  form      Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  order     Int
  type      QuestionType
  prompt    String
  required  Boolean      @default(true)
  options   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  answers   Answer[]

  @@unique([formId, order])
  @@index([formId])
}

model Submission {
  id              String   @id @default(cuid())
  formId          String
  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedAt     DateTime @default(now())
  totalDurationMs Int?
  answers         Answer[]

  @@index([formId])
  @@index([submittedAt])
}

model Answer {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value        Json
  durationMs   Int?

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@index([questionId])
}
