{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "1721285380038545728"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "prod",
      "metadata": {
        "description": "Environment name prefix (e.g. prod, staging)"
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "PostgreSQL administrator login"
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator password"
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
      "metadata": {
        "description": "Container image to deploy (e.g. myacr.azurecr.io/typeform-alt:latest)"
      }
    },
    "authSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Auth.js signing secret (openssl rand -hex 32)"
      }
    },
    "authMicrosoftEntraIdId": {
      "type": "string",
      "metadata": {
        "description": "Microsoft Entra application (client) ID"
      }
    },
    "authMicrosoftEntraIdSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Microsoft Entra client secret"
      }
    },
    "authMicrosoftEntraIdIssuer": {
      "type": "string",
      "metadata": {
        "description": "Microsoft Entra issuer URL"
      }
    },
    "deployerPrincipalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Object ID of the principal running this deployment (for Key Vault secret writes)"
      }
    }
  },
  "variables": {
    "resourcePrefix": "[format('typeform-alt-{0}', parameters('environmentName'))]",
    "vnetName": "[format('vnet-{0}', variables('resourcePrefix'))]",
    "acrName": "[replace(format('acr{0}', variables('resourcePrefix')), '-', '')]",
    "pgName": "[format('pg-{0}', variables('resourcePrefix'))]",
    "kvName": "[format('kv-{0}', variables('resourcePrefix'))]",
    "acaEnvName": "[format('cae-{0}', variables('resourcePrefix'))]",
    "acaAppName": "typeform-alt",
    "acaJobName": "typeform-alt-migrate",
    "kvUri": "[format('https://{0}{1}/', variables('kvName'), environment().suffixes.keyvaultDns)]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.0.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "apps",
            "properties": {
              "addressPrefix": "10.0.1.0/24",
              "delegations": [
                {
                  "name": "Microsoft.App.environments",
                  "properties": {
                    "serviceName": "Microsoft.App/environments"
                  }
                }
              ]
            }
          },
          {
            "name": "data",
            "properties": {
              "addressPrefix": "10.0.2.0/24",
              "privateEndpointNetworkPolicies": "Disabled"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": true
      }
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.postgres.database.azure.com",
      "location": "global"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.postgres.database.azure.com', 'pg-vnet-link')]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-12-01-preview",
      "name": "[variables('pgName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_B2ms",
        "tier": "Burstable"
      },
      "properties": {
        "version": "16",
        "administratorLogin": "[parameters('postgresAdminLogin')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "storage": {
          "storageSizeGB": 32,
          "autoGrow": "Enabled"
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        },
        "network": {
          "delegatedSubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', split(format('{0}/data', variables('vnetName')), '/')[0], split(format('{0}/data', variables('vnetName')), '/')[1])]",
          "privateDnsZoneArmResourceId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.postgres.database.azure.com')]",
        "[resourceId('Microsoft.Network/privateDnsZones/virtualNetworkLinks', 'privatelink.postgres.database.azure.com', 'pg-vnet-link')]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('pgName'), 'typeform')]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.UTF8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "publicNetworkAccess": "Disabled",
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices"
        }
      }
    },
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-09-01",
      "name": "[format('pe-{0}', variables('kvName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[format('{0}/subnets/data', resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "kv-connection",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
              "groupIds": [
                "vault"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.vaultcore.azure.net",
      "location": "global"
    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.vaultcore.azure.net', 'kv-vnet-link')]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.vaultcore.azure.net')]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', format('pe-{0}', variables('kvName')), 'kvDnsZoneGroup')]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "config",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.vaultcore.azure.net')]"
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.vaultcore.azure.net')]",
        "[resourceId('Microsoft.Network/privateEndpoints', format('pe-{0}', variables('kvName')))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'database-url')]",
      "properties": {
        "value": "[format('postgresql://{0}:{1}@{2}:5432/typeform?schema=public&sslmode=require', parameters('postgresAdminLogin'), parameters('postgresAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName')), '2023-12-01-preview').fullyQualifiedDomainName)]"
      },
      "dependsOn": [
        "[extensionResourceId(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), parameters('deployerPrincipalId'), 'b86a8fe2-44ce-4948-aee5-eccb2c155cd7'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'auth-secret')]",
      "properties": {
        "value": "[parameters('authSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'auth-microsoft-entra-id-id')]",
      "properties": {
        "value": "[parameters('authMicrosoftEntraIdId')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'auth-microsoft-entra-id-secret')]",
      "properties": {
        "value": "[parameters('authMicrosoftEntraIdSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('kvName'), 'auth-microsoft-entra-id-issuer')]",
      "properties": {
        "value": "[parameters('authMicrosoftEntraIdIssuer')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "condition": "[not(empty(parameters('deployerPrincipalId')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), parameters('deployerPrincipalId'), 'b86a8fe2-44ce-4948-aee5-eccb2c155cd7')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b86a8fe2-44ce-4948-aee5-eccb2c155cd7')]",
        "principalId": "[parameters('deployerPrincipalId')]",
        "principalType": "User"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('acaEnvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "vnetConfiguration": {
          "infrastructureSubnetId": "[format('{0}/subnets/apps', resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')))]",
          "internal": false
        },
        "workloadProfiles": [
          {
            "name": "Consumption",
            "workloadProfileType": "Consumption"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('acaAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 3000,
            "transport": "auto",
            "allowInsecure": false
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]",
              "username": "[variables('acrName')]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": [
            {
              "name": "acr-password",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "database-url",
              "keyVaultUrl": "[format('{0}secrets/database-url', variables('kvUri'))]",
              "identity": "system"
            },
            {
              "name": "auth-secret",
              "keyVaultUrl": "[format('{0}secrets/auth-secret', variables('kvUri'))]",
              "identity": "system"
            },
            {
              "name": "auth-microsoft-entra-id-id",
              "keyVaultUrl": "[format('{0}secrets/auth-microsoft-entra-id-id', variables('kvUri'))]",
              "identity": "system"
            },
            {
              "name": "auth-microsoft-entra-id-secret",
              "keyVaultUrl": "[format('{0}secrets/auth-microsoft-entra-id-secret', variables('kvUri'))]",
              "identity": "system"
            },
            {
              "name": "auth-microsoft-entra-id-issuer",
              "keyVaultUrl": "[format('{0}secrets/auth-microsoft-entra-id-issuer', variables('kvUri'))]",
              "identity": "system"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "[variables('acaAppName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              },
              "env": [
                {
                  "name": "DATABASE_URL",
                  "secretRef": "database-url"
                },
                {
                  "name": "NODE_ENV",
                  "value": "production"
                },
                {
                  "name": "AUTH_SECRET",
                  "secretRef": "auth-secret"
                },
                {
                  "name": "AUTH_URL",
                  "value": "[format('https://{0}', format('{0}.{1}', variables('acaAppName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName')), '2024-03-01').defaultDomain))]"
                },
                {
                  "name": "AUTH_MICROSOFT_ENTRA_ID_ID",
                  "secretRef": "auth-microsoft-entra-id-id"
                },
                {
                  "name": "AUTH_MICROSOFT_ENTRA_ID_SECRET",
                  "secretRef": "auth-microsoft-entra-id-secret"
                },
                {
                  "name": "AUTH_MICROSOFT_ENTRA_ID_ISSUER",
                  "secretRef": "auth-microsoft-entra-id-issuer"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 3,
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "50"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]"
      ]
    },
    {
      "type": "Microsoft.App/jobs",
      "apiVersion": "2024-03-01",
      "name": "[variables('acaJobName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]",
        "configuration": {
          "triggerType": "Manual",
          "replicaTimeout": 300,
          "replicaRetryLimit": 1,
          "registries": "[reference(resourceId('Microsoft.App/containerApps', variables('acaAppName')), '2024-03-01').configuration.registries]",
          "secrets": "[reference(resourceId('Microsoft.App/containerApps', variables('acaAppName')), '2024-03-01').configuration.secrets]"
        },
        "template": {
          "containers": [
            {
              "name": "migrate",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "command": [
                "sh",
                "-c",
                "npx prisma migrate deploy && npx prisma db seed"
              ],
              "env": [
                {
                  "name": "DATABASE_URL",
                  "secretRef": "database-url"
                }
              ]
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', variables('acaAppName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), resourceId('Microsoft.App/containerApps', variables('acaAppName')), '4633458b-17de-408a-b874-0445c86b69e0')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e0')]",
        "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('acaAppName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', variables('acaAppName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('kvName')), resourceId('Microsoft.App/jobs', variables('acaJobName')), '4633458b-17de-408a-b874-0445c86b69e0')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e0')]",
        "principalId": "[reference(resourceId('Microsoft.App/jobs', variables('acaJobName')), '2024-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/jobs', variables('acaJobName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('kvName'))]"
      ]
    }
  ],
  "outputs": {
    "containerAppFqdn": {
      "type": "string",
      "value": "[format('{0}.{1}', variables('acaAppName'), reference(resourceId('Microsoft.App/managedEnvironments', variables('acaEnvName')), '2024-03-01').defaultDomain)]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('kvName')]"
    },
    "postgresHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName')), '2023-12-01-preview').fullyQualifiedDomainName]"
    }
  }
}