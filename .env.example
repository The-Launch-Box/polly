# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Copy this file to .env and use as-is for local Docker Compose dev.
# ──────────────────────────────────────────────────────────────────────────────

# Prisma / PostgreSQL connection string
# Local: matches docker-compose.yml defaults
# Azure: postgresql://<user>:<pass>@<pg-host>.postgres.database.azure.com:5432/typeform?schema=public&sslmode=require
DATABASE_URL="postgresql://typeform:typeform@localhost:5432/typeform?schema=public"

# ──────────────────────────────────────────────────────────────────────────────
# AZURE (leave blank for local dev — these are injected by Container Apps)
# ──────────────────────────────────────────────────────────────────────────────

# Key Vault URI — used if you implement @azure/keyvault-secrets in a startup script
# e.g. https://kv-typeform-alt-prod.vault.azure.net/
AZURE_KEY_VAULT_URI=

# Managed identity client ID (user-assigned) — leave blank to use system-assigned
AZURE_CLIENT_ID=

# ──────────────────────────────────────────────────────────────────────────────
# FUTURE — Next.js Auth (NextAuth.js / Auth.js)
# ──────────────────────────────────────────────────────────────────────────────

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# Public URL of the app (required by NextAuth for OAuth redirects)
# Local: http://localhost:3000
# Azure: https://<app-name>.azurecontainerapps.io
NEXTAUTH_URL=
